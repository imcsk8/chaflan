<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Event - Chaflan</title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
    <div class="container form-container">
        <h1>Update Event</h1>
        <form id="updateEventForm">
            <input type="hidden" id="event_id" value="{{ event.id }}">
            
            <div class="form-group">
                <label for="name">Event Name *</label>
                <input type="text" id="name" name="name" required value="{{ event.name }}">
            </div>

            <div class="form-group">
                <label for="venue">Venue *</label>
                <input type="text" id="venue" name="venue" required value="{{ event.venue }}">
            </div>

            <div class="form-group">
                <label for="address">Address</label>
                <input type="text" id="address" name="address" value="{{ event.address }}">
            </div>

            <div class="form-group">
                <label for="url">Related URL *</label>
                <input type="url" id="url" name="url" required value="{{ event.url }}">
            </div>

            <div class="form-group">
                <label for="image">Event Image (Leave empty to keep current)</label>
                {{#if event.image}}
                    <div style="margin-bottom: 0.5rem;">
                        <small>Current image:</small><br>
                        <img src="{{ event.image }}" alt="Current image" style="height: 50px; border-radius: 4px;">
                    </div>
                {{/if}}
                <input type="file" id="image" name="image" accept="image/*">
            </div>

            <div class="form-group-flex">
                <div class="form-group">
                    <label for="starts_at">Starts At *</label>
                    <input type="datetime-local" id="starts_at" name="starts_at" required value="{{ event.starts_at }}">
                </div>
                <div class="form-group">
                    <label for="ends_at">Ends At *</label>
                    <input type="datetime-local" id="ends_at" name="ends_at" required value="{{ event.ends_at }}">
                </div>
            </div>

            <div class="form-group">
                <label for="contactname">Contact Name</label>
                <input type="text" id="contactname" name="contactname" value="{{ event.contactname }}">
            </div>

            <div class="form-group">
                <label for="comments">Comments</label>
                <textarea id="comments" name="comments">{{ event.comments }}</textarea>
            </div>

            <div class="button-group">
                <button type="button" class="btn-secondary" onclick="window.location.href='/events/{{ event.id }}?format=text/html'">Cancel</button>
                <button type="submit" class="btn-success">Update Event</button>
            </div>
        </form>
        <div id="message"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="/public/js/events.js"></script>
</body>
</html>
