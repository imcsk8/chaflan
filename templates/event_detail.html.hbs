<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ event.name }} - Chaflan</title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
    <div class="container detail-container">
        <h1>{{ event.name }}</h1>
        
        <div class="meta">
            <div class="meta-item"><span class="meta-label">Venue:</span> {{ event.venue }}</div>
            {{#if event.address}}
            <div class="meta-item"><span class="meta-label">Address:</span> {{ event.address }}</div>
            {{/if}}
            <div class="meta-item"><span class="meta-label">Starts:</span> {{ event.starts_at }}</div>
            <div class="meta-item"><span class="meta-label">Ends:</span> {{ event.ends_at }}</div>
            {{#if event.contactname}}
            <div class="meta-item"><span class="meta-label">Contact:</span> {{ event.contactname }}</div>
            {{/if}}
        </div>

        {{#if event.image}}
        <div class="image-container">
            <img src="{{ event.image }}" alt="{{ event.name }}" class="event-image">
        </div>
        {{/if}}

        {{#if event.comments}}
        <div class="comments">
            <strong>Notes:</strong><br>
            {{ event.comments }}
        </div>
        {{/if}}

        <div class="nav-links">
            <a href="/events" class="btn btn-secondary">← Back to List</a>
            {{#if event.url}}
            <a href="{{ event.url }}" target="_blank" class="btn btn-primary">Visit Event Website</a>
            {{/if}}
        </div>
    </div>
</body>
</html>
