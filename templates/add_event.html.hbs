<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Event - Chaflan</title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
    <div class="container form-container">
        <h1>Create New Event</h1>
        <form id="addEventForm">
            <div class="form-group">
                <label for="name">Event Name *</label>
                <input type="text" id="name" name="name" required placeholder="e.g., Tech Conference 2026">
            </div>

            <div class="form-group">
                <label for="venue">Venue *</label>
                <input type="text" id="venue" name="venue" required placeholder="e.g., Convention Center">
            </div>

            <div class="form-group">
                <label for="address">Address</label>
                <input type="text" id="address" name="address" placeholder="e.g., 123 Main St, City">
            </div>

            <div class="form-group">
                <label for="url">Related URL *</label>
                <input type="url" id="url" name="url" required placeholder="https://example.com">
            </div>

            <div class="form-group">
                <label for="image">Event Image</label>
                <input type="file" id="image" name="image" accept="image/*">
            </div>

            <div class="form-group-flex">
                <div class="form-group">
                    <label for="starts_at">Starts At *</label>
                    <input type="datetime-local" id="starts_at" name="starts_at" required>
                </div>
                <div class="form-group">
                    <label for="ends_at">Ends At *</label>
                    <input type="datetime-local" id="ends_at" name="ends_at" required>
                </div>
            </div>

            <div class="form-group">
                <label for="contactname">Contact Name</label>
                <input type="text" id="contactname" name="contactname" placeholder="Name of the organizer">
            </div>

            <div class="form-group">
                <label for="comments">Comments</label>
                <textarea id="comments" name="comments" placeholder="Additional details..."></textarea>
            </div>

            <div class="button-group">
                <button type="button" class="btn-secondary" onclick="window.location.href='/events'">Cancel</button>
                <button type="submit" class="btn-success">Save Event</button>
            </div>
        </form>
        <div id="message"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="/public/js/events.js"></script>
</body>
</html>
