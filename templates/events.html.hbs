<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Events - Chaflan</title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
    <div class="container">
        <header class="event-header">
            <h1>Events</h1>
            {{#if is_logged_in}}
                <button onclick="window.location.href='/events/add_page'" class="btn-success">+ Add Event</button>
            {{else}}
                <a href="/login" class="btn btn-primary">Login</a>
            {{/if}}
        </header>
        <p>Events:</p>
        <ul>
            {{#each events}}
            <li><a href="/events/{{ this.id }}?format=text/html">{{ this.name }}</a>&nbsp;{{this.starts_at}} {{this.ends_at}}</li>
            {{else}}
            <p> No events yet</p>
            {{/each}}
        </ul>
        <h3>Total: {{ len events }}</h3>
    </div>
</body>
</html>
