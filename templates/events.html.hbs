<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Events</title>
</head>
<body>
    <section id="hello">
        <header style="display: flex; justify-content: space-between; align-items: center;">
            <h1>Events</h1>
            {{#if is_logged_in}}
                <button onclick="window.location.href='/events/add_page'" style="padding: 0.5rem 1rem; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer;">+ Add Event</button>
            {{else}}
                <a href="/login">Login</a>
            {{/if}}
        </header>
        <p>Events:</p>
        <ul>
            {{#each events}}
            <li><a href="/events/{{ this.id }}">{{ this.name }}</a>&nbsp;{{this.starts_at}} {{this.ends_at}}</li>
            {{else}}
            <p> No events yet</p>
            {{/each}}
        </ul>
        <h3>Total: {{ len events }}</h3>
    </section>
</body>
</html>
